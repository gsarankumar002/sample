<!DOCTYPE html>
<html lang="en">
<head>
<!body>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Work Freaks | Cloud Interview Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getFirestore, collection, addDoc, getDocs, updateDoc, deleteDoc, doc, onSnapshot } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

        // Firebase Configuration (Replace with your own details from Firebase Console)
        const firebaseConfig = {
            apiKey: "YOUR_API_KEY",
            authDomain: "YOUR_PROJECT_ID.firebaseapp.com",
            projectId: "YOUR_PROJECT_ID",
            storageBucket: "YOUR_PROJECT_ID.appspot.com",
            messagingSenderId: "YOUR_SENDER_ID",
            appId: "YOUR_APP_ID"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const candidatesCol = collection(db, "candidates");

        // --- Camera Logic ---
        let capturedImageData = "";
        window.initCamera = async function() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: true });
                const video = document.getElementById('video');
                video.srcObject = stream;
                video.classList.remove('hidden');
                document.getElementById('camPlaceholder').classList.add('hidden');
                document.getElementById('snapBtn').classList.remove('hidden');
                document.getElementById('startBtn').classList.add('hidden');
            } catch (err) { alert("Camera Permission Required!"); }
        };

        window.takePhoto = function() {
            const video = document.getElementById('video');
            const canvas = document.getElementById('canvas');
            const snapBtn = document.getElementById('snapBtn');
            if (snapBtn.innerText === "Retake") {
                canvas.classList.add('hidden'); video.classList.remove('hidden');
                snapBtn.innerText = "Capture"; capturedImageData = "";
            } else {
                const context = canvas.getContext('2d');
                canvas.width = video.videoWidth; canvas.height = video.videoHeight;
                context.drawImage(video, 0, 0, canvas.width, canvas.height);
                capturedImageData = canvas.toDataURL('image/webp', 0.5); // Compressed
                video.classList.add('hidden'); canvas.classList.remove('hidden');
                snapBtn.innerText = "Retake";
            }
        };

        // --- Save to Cloud ---
        document.getElementById('entryForm').onsubmit = async function(e) {
            e.preventDefault();
            if (!capturedImageData) return alert("Photo required!");
            
            const btn = e.target.querySelector('button[type="submit"]');
            btn.innerText = "Saving..."; btn.disabled = true;

            try {
                await addDoc(candidatesCol, {
                    name: document.getElementById('name').value,
                    phone: document.getElementById('phone').value,
                    dob: document.getElementById('dob').value,
                    position: document.getElementById('position').value,
                    native: document.getElementById('native').value,
                    photo: capturedImageData,
                    appliedAt: new Date().toLocaleString(),
                    status: "Pending"
                });
                alert("Data Saved to Cloud!");
                location.reload();
            } catch (e) { alert("Error saving data: " + e); }
        };

        // --- Load Data (Real-time) ---
        window.loadData = function() {
            onSnapshot(candidatesCol, (snapshot) => {
                const table = document.getElementById('tableContent');
                table.innerHTML = snapshot.docs.map(docSnap => {
                    const item = docSnap.data();
                    const id = docSnap.id;
                    return `
                        <tr class="border-b hover:bg-slate-50 transition">
                            <td class="p-4"><img src="${item.photo}" class="w-12 h-12 object-cover rounded-full"></td>
                            <td class="p-4"><b>${item.name}</b><br><small>${item.phone}</small></td>
                            <td class="p-4 text-indigo-600">${item.position}</td>
                            <td class="p-4"><span class="px-2 py-1 rounded-full text-[10px] font-bold ${item.status === 'Selected' ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700'}">${item.status}</span></td>
                            <td class="p-4">
                                <button onclick="deleteRecord('${id}')" class="text-red-500 font-bold">Delete</button>
                            </td>
                        </tr>`;
                }).join('');
            });
        };

        window.deleteRecord = async function(id) {
            if(confirm("Delete this candidate?")) {
                await deleteDoc(doc(db, "candidates", id));
            }
        };

        window.checkPin = function() {
            if(document.getElementById('pinInput').value === "1234") {
                document.getElementById('pinArea').classList.add('hidden');
                document.getElementById('dashboard').classList.remove('hidden');
                loadData();
            } else { alert("Wrong PIN!"); }
        };

        window.showSection = function(id) {
            document.getElementById('candidate-section').classList.toggle('hidden', id !== 'candidate');
            document.getElementById('manager-section').classList.toggle('hidden', id !== 'manager');
        };
    </script>
</head>
<body class="bg-slate-50 min-h-screen">
    <nav class="bg-indigo-700 p-4 text-white flex justify-between shadow-lg">
        <h1 class="font-bold">Work Freaks Business</h1>
        <div class="flex gap-2">
            <button onclick="showSection('candidate')" class="text-sm bg-indigo-800 px-3 py-1 rounded">Candidate</button>
            <button onclick="showSection('manager')" class="text-sm bg-white text-indigo-700 px-3 py-1 rounded">Manager</button>
        </div>
    </nav>

    <div class="container mx-auto p-4">
        <section id="candidate-section" class="max-w-md mx-auto bg-white p-6 rounded-xl shadow-md">
            <form id="entryForm" class="space-y-4">
                <input type="text" id="name" placeholder="Full Name" class="w-full border p-2 rounded" required>
                <input type="tel" id="phone" placeholder="Phone" class="w-full border p-2 rounded" required>
                <div class="grid grid-cols-2 gap-2">
                    <input type="date" id="dob" class="w-full border p-2 rounded" required>
                    <input type="text" id="position" placeholder="Position" class="w-full border p-2 rounded" required>
                </div>
                <input type="text" id="native" placeholder="Native Place" class="w-full border p-2 rounded" required>
                
                <div class="bg-slate-100 p-4 rounded text-center">
                    <video id="video" autoplay playsinline class="hidden mx-auto rounded mb-2"></video>
                    <canvas id="canvas" class="hidden mx-auto rounded mb-2"></canvas>
                    <div id="camPlaceholder">📷 Camera Required</div>
                    <button type="button" id="startBtn" onclick="initCamera()" class="bg-indigo-500 text-white px-4 py-1 rounded mt-2">Open Camera</button>
                    <button type="button" id="snapBtn" onclick="takePhoto()" class="hidden bg-rose-500 text-white px-4 py-1 rounded mt-2">Capture</button>
                </div>
                <button type="submit" class="w-full bg-indigo-600 text-white py-3 rounded-lg font-bold">SUBMIT TO CLOUD</button>
            </form>
        </section>

        <section id="manager-section" class="hidden">
            <div id="pinArea" class="max-w-sm mx-auto bg-white p-8 rounded-xl shadow text-center">
                <input type="password" id="pinInput" placeholder="Enter PIN" class="w-full border-b-2 p-2 mb-4 text-center">
                <button onclick="checkPin()" class="w-full bg-indigo-600 text-white py-2 rounded">Login</button>
            </div>
            <div id="dashboard" class="hidden bg-white rounded-xl shadow overflow-hidden">
                <table class="w-full text-left">
                    <thead class="bg-slate-100">
                        <tr><th class="p-4">Photo</th><th class="p-4">Name</th><th class="p-4">Role</th><th class="p-4">Status</th><th class="p-4">Action</th></tr>
                    </thead>
                    <tbody id="tableContent"></tbody>
                </table>
            </div>
        </section>
    </div>
</body>
</html>